#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="/etc/apt-thirdparty-handler/apps.d"
STATE_DIR="/var/lib/apt-thirdparty-handler"
DEFAULT_REFRESH_INTERVAL_SEC=86400
WHITELIST_CONFIG_FILE="/etc/apt-thirdparty-handler/whitelist.conf"
WHITELIST_KEYRING="/usr/share/apt-thirdparty-handler/trustedkeys.gpg"
WHITELIST_BASE_URL=""
WHITELIST_ARCHIVE_URL=""
WHITELIST_SIG_URL=""
WHITELIST_KEY_URL=""

die() {
  echo "Error: $*" >&2
  exit 1
}

info() {
  echo "[apt-thirdparty-handler] $*"
}

read_os_release_var() {
  local key="$1"
  local file="${2:-/etc/os-release}"
  awk -F= -v key="$key" '
    $1 == key {
      val = $2
      gsub(/^"/, "", val)
      gsub(/"$/, "", val)
      print val
      exit
    }
  ' "$file" 2>/dev/null || true
}

resolve_ubuntu_codename() {
  local codename=""

  # Ubuntu and most derivatives (including Mint) often expose this directly.
  codename="$(read_os_release_var "UBUNTU_CODENAME")"
  if [ -n "$codename" ]; then
    printf '%s\n' "$codename"
    return 0
  fi

  # Fallback for some Ubuntu setups.
  codename="$(read_os_release_var "VERSION_CODENAME")"
  if [ -n "$codename" ]; then
    printf '%s\n' "$codename"
    return 0
  fi

  # Linux Mint commonly ships Ubuntu base codename here.
  if [ -f /etc/upstream-release/lsb-release ]; then
    codename="$(read_os_release_var "DISTRIB_CODENAME" "/etc/upstream-release/lsb-release")"
    if [ -n "$codename" ]; then
      printf '%s\n' "$codename"
      return 0
    fi
  fi

  # Last resort when lsb-release is available.
  if command -v lsb_release >/dev/null 2>&1; then
    codename="$(lsb_release -u -sc 2>/dev/null || true)"
    if [ -z "$codename" ]; then
      codename="$(lsb_release -sc 2>/dev/null || true)"
    fi
    if [ -n "$codename" ]; then
      printf '%s\n' "$codename"
      return 0
    fi
  fi

  die "Unable to detect Ubuntu codename for repository template expansion."
}

resolve_repo_line() {
  local line="$REPO_LINE"
  local needs_codename=0
  local codename=""

  if [[ "$line" == *"__UBUNTU_CODENAME__"* ]] || [[ "$line" == *'${UBUNTU_CODENAME}'* ]] || [[ "$line" == *'$UBUNTU_CODENAME'* ]]; then
    needs_codename=1
  fi

  if [ "$needs_codename" -eq 1 ]; then
    codename="$(resolve_ubuntu_codename)"
    line="${line//__UBUNTU_CODENAME__/$codename}"
    line="${line//\$\{UBUNTU_CODENAME\}/$codename}"
    line="${line//\$UBUNTU_CODENAME/$codename}"
  fi

  printf '%s\n' "$line"
}

can_use_zenity() {
  command -v zenity >/dev/null 2>&1 && { [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; }
}

load_whitelist_settings() {
  if [ -f "$WHITELIST_CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    . "$WHITELIST_CONFIG_FILE"
  fi

  WHITELIST_BASE_URL="${WHITELIST_BASE_URL:-}"
  WHITELIST_ARCHIVE_URL="${WHITELIST_ARCHIVE_URL:-${WHITELIST_BASE_URL%/}/apps.tar}"
  WHITELIST_SIG_URL="${WHITELIST_SIG_URL:-${WHITELIST_BASE_URL%/}/apps.tar.asc}"
  WHITELIST_KEY_URL="${WHITELIST_KEY_URL:-${WHITELIST_BASE_URL%/}/whitelist-signing.pub}"
}

is_root() {
  [ "${EUID:-$(id -u)}" -eq 0 ]
}

confirm_user() {
  local title="$1"
  local message="$2"
  local zenity_status

  if can_use_zenity; then
    # --no-markup avoids GTK warnings when message contains '&' (e.g. URL query params).
    if zenity --question --title="$title" --width=520 --no-markup --text="$message"; then
      return 0
    fi
    zenity_status=$?
    # 1 means user clicked "Cancel". Other values are runtime/display issues.
    if [ "$zenity_status" -eq 1 ]; then
      return 1
    fi
    info "Zenity unavailable at runtime; falling back to terminal prompt."
  fi

  [ -t 0 ] || die "No interactive prompt available to confirm action."
  echo "$message"
  read -r -p "Continue? [y/N] " ans
  case "${ans}" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

require_cmds() {
  local missing=0
  for cmd in curl gpg gpgv tar apt-get; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "Missing command: $cmd" >&2
      missing=1
    fi
  done
  [ "$missing" -eq 0 ] || die "Missing dependencies."
}

validate_app_id() {
  local app_id="$1"
  [[ "$app_id" =~ ^[a-z0-9][a-z0-9._-]*$ ]] || die "Invalid app ID: $app_id"
}

config_exists() {
  local app_id="$1"
  [ -f "$CONFIG_DIR/$app_id.conf" ]
}

get_refresh_interval_sec() {
  local v="${WHITELIST_REFRESH_INTERVAL_SEC:-$DEFAULT_REFRESH_INTERVAL_SEC}"
  if [[ "$v" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$v"
  else
    printf '%s\n' "$DEFAULT_REFRESH_INTERVAL_SEC"
  fi
}

refresh_needed() {
  local stamp="$STATE_DIR/last_refresh_epoch"
  local now interval last

  interval="$(get_refresh_interval_sec)"
  [ "$interval" -gt 0 ] || return 1
  [ -f "$stamp" ] || return 0

  now="$(date +%s)"
  last="$(cat "$stamp" 2>/dev/null || echo 0)"
  [[ "$last" =~ ^[0-9]+$ ]] || return 0

  [ $((now - last)) -ge "$interval" ]
}

update_refresh_stamp() {
  mkdir -p "$STATE_DIR"
  printf '%s\n' "$(date +%s)" > "$STATE_DIR/last_refresh_epoch"
}

validate_conf_file() {
  local conf_file="$1"
  local file_app_id conf_app_id

  file_app_id="$(basename "$conf_file" .conf)"
  validate_app_id "$file_app_id"

  conf_app_id="$(awk -F'"' '/^APP_ID="/ { print $2; exit }' "$conf_file")"
  [ -n "$conf_app_id" ] || die "Missing APP_ID in $conf_file"
  [ "$conf_app_id" = "$file_app_id" ] || die "APP_ID mismatch in $conf_file"
}

refresh_whitelist_index() {
  local tmp_dir archive sig_file conf_count
  load_whitelist_settings

  [ -n "$WHITELIST_BASE_URL" ] || {
    info "Whitelist URL not configured; using packaged/local allowlist."
    return 0
  }
  ensure_whitelist_keyring

  tmp_dir="$(mktemp -d)"

  archive="$tmp_dir/apps.tar"
  sig_file="$tmp_dir/apps.tar.asc"

  info "Refreshing whitelist index..."
  info "Downloading archive: $WHITELIST_ARCHIVE_URL"
  curl -fsSL "$WHITELIST_ARCHIVE_URL" -o "$archive"
  info "Downloading signature: $WHITELIST_SIG_URL"
  curl -fsSL "$WHITELIST_SIG_URL" -o "$sig_file"

  info "Verifying signature..."
  gpgv --keyring "$WHITELIST_KEYRING" "$sig_file" "$archive" >/dev/null

  mkdir -p "$tmp_dir/extracted"
  tar -xf "$archive" -C "$tmp_dir/extracted"
  [ -d "$tmp_dir/extracted/apps.d" ] || die "Invalid whitelist archive: missing apps.d/"

  conf_count=0
  shopt -s nullglob
  for conf_file in "$tmp_dir"/extracted/apps.d/*.conf; do
    validate_conf_file "$conf_file"
    conf_count=$((conf_count + 1))
  done
  shopt -u nullglob
  [ "$conf_count" -gt 0 ] || die "Invalid whitelist archive: no .conf files"

  mkdir -p "$CONFIG_DIR"
  rm -f "$CONFIG_DIR"/*.conf
  cp "$tmp_dir"/extracted/apps.d/*.conf "$CONFIG_DIR"/
  chmod 0644 "$CONFIG_DIR"/*.conf

  update_refresh_stamp
  rm -rf "$tmp_dir"
  info "Whitelist refreshed: $conf_count app(s) installed to $CONFIG_DIR"
}

ensure_whitelist_keyring() {
  local tmp_keyring keyring_dir

  [ -f "$WHITELIST_KEYRING" ] && return 0
  [ -n "$WHITELIST_KEY_URL" ] || die "Whitelist key URL is not configured."

  keyring_dir="$(dirname "$WHITELIST_KEYRING")"
  mkdir -p "$keyring_dir"

  tmp_keyring="$(mktemp)"

  info "Trusted keyring missing; bootstrapping from: $WHITELIST_KEY_URL"
  curl -fsSL "$WHITELIST_KEY_URL" | gpg --dearmor > "$tmp_keyring"
  install -m 0644 "$tmp_keyring" "$WHITELIST_KEYRING"
  rm -f "$tmp_keyring"
  info "Installed trusted keyring: $WHITELIST_KEYRING"
}

build_install_summary() {
  local effective_repo_line
  effective_repo_line="$(resolve_repo_line)"
  printf 'Install %s?\n\nApp ID: %s\nPackage: %s\n\nKey: %s\nRepository: %s' \
    "$DISPLAY_NAME" "$APP_ID" "$PACKAGE_NAME" "$KEY_URL" "$effective_repo_line"
}

run_pkexec_for_app() {
  local app_id="$1"
  local -a cmd
  cmd=(pkexec)

  # Preserve GUI variables so root-side confirmations can use zenity.
  if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${XAUTHORITY:-}" ] || [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
    cmd+=(env)
    [ -n "${DISPLAY:-}" ] && cmd+=("DISPLAY=$DISPLAY")
    [ -n "${WAYLAND_DISPLAY:-}" ] && cmd+=("WAYLAND_DISPLAY=$WAYLAND_DISPLAY")
    [ -n "${XAUTHORITY:-}" ] && cmd+=("XAUTHORITY=$XAUTHORITY")
    [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ] && cmd+=("DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS")
  fi

  cmd+=("$0" --run-id "$app_id")
  info "Launching privileged command..."
  info "Command: ${cmd[*]}"
  "${cmd[@]}"
}

load_app_config() {
  local app_id="$1"
  local conf="$CONFIG_DIR/$app_id.conf"
  [ -f "$conf" ] || die "Configuration not found: $conf"

  # shellcheck source=/dev/null
  . "$conf"

  : "${APP_ID:?APP_ID is required}"
  : "${DISPLAY_NAME:?DISPLAY_NAME is required}"
  : "${KEY_URL:?KEY_URL is required}"
  : "${KEYRING_PATH:?KEYRING_PATH is required}"
  : "${LIST_FILE_PATH:?LIST_FILE_PATH is required}"
  : "${REPO_LINE:?REPO_LINE is required}"
  : "${PACKAGE_NAME:?PACKAGE_NAME is required}"

  [ "$APP_ID" = "$app_id" ] || die "APP_ID mismatch in config ($APP_ID != $app_id)"
}

install_repo_and_package() {
  local tmp_key effective_repo_line
  local list_backup=""
  local list_existed=0
  tmp_key="$(mktemp)"
  trap 'rm -f "${tmp_key:-}" "${list_backup:-}"' EXIT
  effective_repo_line="$(resolve_repo_line)"

  mkdir -p /etc/apt/keyrings

  info "Using key URL: $KEY_URL"
  info "Installing key to: $KEYRING_PATH"
  info "Downloading and dearmoring GPG key..."
  curl -fsSL "$KEY_URL" | gpg --dearmor > "$tmp_key"
  install -m 0644 "$tmp_key" "$KEYRING_PATH"

  info "Writing repository file: $LIST_FILE_PATH"
  info "Repository line: $effective_repo_line"
  if [ -f "$LIST_FILE_PATH" ]; then
    list_existed=1
    list_backup="$(mktemp)"
    cp "$LIST_FILE_PATH" "$list_backup"
  fi
  printf '%s\n' "$effective_repo_line" > "$LIST_FILE_PATH"
  chmod 0644 "$LIST_FILE_PATH"

  info "Running apt-get update..."
  if ! apt-get update; then
    info "apt-get update failed after adding repository."
    if [ "$list_existed" -eq 1 ] && [ -n "$list_backup" ] && [ -f "$list_backup" ]; then
      info "Restoring previous repository file: $LIST_FILE_PATH"
      cp "$list_backup" "$LIST_FILE_PATH"
      chmod 0644 "$LIST_FILE_PATH"
    else
      info "Removing repository file: $LIST_FILE_PATH"
      rm -f "$LIST_FILE_PATH"
    fi
    info "Refreshing package lists after rollback..."
    apt-get update || true
    die "Repository update failed; repository change rolled back."
  fi

  info "Installing package: $PACKAGE_NAME"
  apt-get install -y "$PACKAGE_NAME"

  info "Installation completed for: $DISPLAY_NAME"
}

run_as_root() {
  local app_id="$1"
  local had_local_config=0
  local needs_refresh=0
  validate_app_id "$app_id"
  require_cmds

  if config_exists "$app_id"; then
    had_local_config=1
  fi
  if refresh_needed || [ "$had_local_config" -eq 0 ]; then
    needs_refresh=1
  fi

  if [ "$needs_refresh" -eq 1 ]; then
    refresh_whitelist_index
  fi

  load_app_config "$app_id"

  # If the app config was not known locally at click time, ask one explicit
  # confirmation with exact package/repository details after signed refresh.
  if [ "$had_local_config" -eq 0 ]; then
    if ! confirm_user "Confirm package installation" "$(build_install_summary)"; then
      info "Cancelled by user after whitelist refresh."
      exit 0
    fi
  fi

  install_repo_and_package
}

extract_app_id_from_uri() {
  local uri="$1"
  local app_id

  app_id="${uri#apt-thirdparty://}"
  app_id="${app_id%%/*}"
  app_id="${app_id%%\?*}"
  app_id="${app_id%%#*}"
  [ -n "$app_id" ] || die "Invalid URI: $uri"
  printf '%s\n' "$app_id"
}

run_interactive() {
  local uri="$1"
  [[ "$uri" == apt-thirdparty://* ]] || die "Unsupported URI: $uri"

  local app_id
  app_id="$(extract_app_id_from_uri "$uri")"
  validate_app_id "$app_id"
  local summary
  if config_exists "$app_id"; then
    load_app_config "$app_id"
    summary="$(build_install_summary)"
  else
    printf -v summary 'Install app "%s"?\n\nNo local allowlist entry found.\nThe handler will refresh the signed whitelist and bootstrap trust key if needed.\nYou will get a second confirmation with exact package/repository details before install.' \
      "$app_id"
  fi

  if ! confirm_user "Third-party APT installation" "$summary"; then
    info "Cancelled by user."
    exit 0
  fi

  local log_file
  log_file="/tmp/apt-thirdparty-handler-${app_id}.log"
  : > "$log_file"
  chmod 0644 "$log_file"

  # If launched via URI handler, there is usually no attached TTY.
  # In normal mode, open a terminal to show live output.
  if [ ! -t 1 ] && command -v x-terminal-emulator >/dev/null 2>&1; then
    if x-terminal-emulator -e bash -lc \
      "{
         '$0' --pkexec-run '$app_id'
       } 2>&1 | tee -a '$log_file';
       status=\${PIPESTATUS[0]};
       echo;
       if [ \$status -eq 0 ]; then
         echo '[apt-thirdparty-handler] Done.'
       else
         echo '[apt-thirdparty-handler] Failed with exit code:' \$status
       fi
       echo '[apt-thirdparty-handler] Log file:' '$log_file'
       echo 'Press Enter to close...';
       read -r _" >/dev/null 2>&1; then
      exit 0
    fi
  fi

  if command -v pkexec >/dev/null 2>&1; then
    if run_pkexec_for_app "$app_id" >>"$log_file" 2>&1; then
      info "Log file: $log_file"
      exit 0
    fi
    info "Log file: $log_file"
    die "Privilege escalation failed (pkexec)."
  fi

  die "pkexec not found. Install policykit-1."
}

main() {
  if [ "${1:-}" = "--pkexec-run" ]; then
    shift
    [ $# -eq 1 ] || die "Usage: $0 --pkexec-run <app-id>"
    command -v pkexec >/dev/null 2>&1 || die "pkexec not found. Install policykit-1."
    run_pkexec_for_app "$1"
    exit 0
  fi

  if [ "${1:-}" = "--refresh-index" ]; then
    shift
    [ $# -eq 0 ] || die "Usage: $0 --refresh-index"
    is_root || die "--refresh-index mode must be executed as root."
    require_cmds
    refresh_whitelist_index
    exit 0
  fi

  if [ "${1:-}" = "--run-id" ]; then
    shift
    [ $# -eq 1 ] || die "Usage: $0 --run-id <app-id>"
    local app_id="$1"
    is_root || die "--run-id mode must be executed as root."
    run_as_root "$app_id"
    exit 0
  fi

  [ $# -eq 1 ] || die "Usage: $0 apt-thirdparty://<app-id>"
  run_interactive "$1"
}

main "$@"
